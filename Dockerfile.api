FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm install --omit=dev

COPY prisma ./prisma
COPY prisma.config.ts ./
# Prisma generate does not need a real DB connection — pass a dummy URL so
# prisma.config.ts can resolve the env variable during the build step.
RUN DATABASE_URL="postgresql://x:x@localhost:5432/x" npx prisma generate

COPY server ./server

EXPOSE 3001

CMD ["sh", "-c", "npx prisma migrate deploy && npx tsx server/index.ts"]
